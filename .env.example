# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Load it locally with `export $(grep -v '^#' .env | xargs)` or use a tool
# like `python-dotenv` / direnv.

# Flask session cookie signing key. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Required in production. Sessions are invalidated when this changes.
FLASK_SECRET_KEY=dev-secret-change-me

# MapTiler API key for the 3D viewer's basemap tiles. Get one free at
# https://www.maptiler.com/ — restrict the key to your deployed domain in
# the MapTiler dashboard so it can't be reused elsewhere.
MAPTILER_KEY=
